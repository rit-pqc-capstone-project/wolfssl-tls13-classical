{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "Build Server",
         "type": "shell",
         "command": "gcc",
         "args": [
            "-I/usr/local/include",
            "-L/usr/local/lib",
            "-o",
            "server",
            "tls13-classical-server/server.c",
            "-lwolfssl",
            "-pthread"
         ],
         "group": {
            "kind": "build",
            "isDefault": true
         }
      },
      {
         "label": "Build Client",
         "type": "shell",
         "command": "gcc",
         "args": [
            "-I/usr/local/include",
            "-L/usr/local/lib",
            "-o",
            "client",
            "tls13-classical-client/client.c",
            "-lwolfssl",
            "-pthread"
         ]
      }
   ]
}